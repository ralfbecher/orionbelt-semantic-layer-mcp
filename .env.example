# OrionBelt Semantic Layer MCP — environment configuration
# Copy to .env and adjust as needed.

# OrionBelt Semantic Layer REST API URL (required)
API_BASE_URL=http://35.187.174.102

# MCP transport: stdio | http | sse
MCP_TRANSPORT=stdio

# Bind host/port for HTTP/SSE transport
MCP_SERVER_HOST=localhost
MCP_SERVER_PORT=9000

# Logging level
LOG_LEVEL=INFO

# HTTP timeout in seconds
API_TIMEOUT=30
